page {
  background-color: #0b0c10;
  color: #c5c6c7;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.page-container {
  width: 100%;
  min-height: 100vh;
  position: relative;
  background: radial-gradient(circle at center, #1f2833 0%, #0b0c10 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.stars {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image:
    radial-gradient(2px 2px at 20px 30px, #ffffff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.8), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 50px 160px, rgba(255,255,255,0.6), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 90px 40px, rgba(255,255,255,0.9), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 130px 80px, rgba(255,255,255,0.5), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 160px 120px, rgba(255,255,255,0.7), rgba(0,0,0,0));
  background-repeat: repeat;
  background-size: 200px 200px;
  opacity: 0.5;
  z-index: 0;
  pointer-events: none;
}

.btn-back {
  position: absolute;
  top: 40rpx;
  left: 0;
  color: #c5c6c7;
  font-size: 28rpx;
  padding: 20rpx;
  z-index: 20;
}

.poster-box {
  width: 660rpx;
  height: 1100rpx;
  background: linear-gradient(180deg, #1f2833 0%, #0b0c10 100%);
  background-image:
    radial-gradient(1px 1px at 20px 30px, #fff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 150px 80px, rgba(255,255,255,0.8), rgba(0,0,0,0)),
    radial-gradient(1px 1px at 300px 200px, rgba(255,255,255,0.6), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 80px 400px, rgba(255,255,255,0.4), rgba(0,0,0,0)),
    radial-gradient(1px 1px at 250px 500px, rgba(255,255,255,0.7), rgba(0,0,0,0));
  border-radius: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5);
  padding: 60rpx 50rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 10;
}

.top-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding-bottom: 30rpx;
}

.poster-title {
  font-size: 40rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  color: #66fcf1;
}

.poster-date {
  font-size: 24rpx;
  opacity: 0.6;
  letter-spacing: 2rpx;
  color: #c5c6c7;
}

.content-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 60rpx 0;
}

.quote-wrapper {
  position: relative;
}

.quote-mark {
  position: absolute;
  top: -60rpx;
  left: -20rpx;
  font-size: 120rpx;
  color: rgba(102, 252, 241, 0.2);
  font-family: serif;
}

.quote {
  font-size: 34rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: #c5c6c7;
  position: relative;
  z-index: 2;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 60rpx;
}

.tag {
  background-color: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #66fcf1;
  letter-spacing: 2rpx;
}

.bottom-section {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 30rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
}

.advice {
  font-size: 26rpx;
  color: #c5c6c7;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.footer-info {
  font-size: 20rpx;
  color: rgba(255,255,255,0.3);
  letter-spacing: 4rpx;
}

.tip-text {
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
  letter-spacing: 2rpx;
  text-align: center;
  position: relative;
  z-index: 10;
}