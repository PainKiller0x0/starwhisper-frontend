page {
  background-color: #0b0c10;
  color: #c5c6c7;
  height: 100%;
}

.page-container {
  width: 100%;
  min-height: 100vh;
  position: relative;
  background: radial-gradient(circle at center, #1f2833 0%, #0b0c10 100%);
}

/* 繁星背景 */
.stars {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image:
    radial-gradient(2px 2px at 20px 30px, #ffffff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.8), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 50px 160px, rgba(255,255,255,0.6), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 90px 40px, rgba(255,255,255,0.9), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 130px 80px, rgba(255,255,255,0.5), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 160px 120px, rgba(255,255,255,0.7), rgba(0,0,0,0));
  background-repeat: repeat;
  background-size: 200px 200px;
  opacity: 0.5;
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航 */
.header {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 30rpx 30rpx;
  background: linear-gradient(180deg, rgba(11, 12, 16, 0.9) 0%, transparent 100%);
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 40rpx;
  color: #ffffff;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #66fcf1;
  letter-spacing: 4rpx;
}

.header-right {
  width: 80rpx;
  display: flex;
  justify-content: flex-end;
}

.clear-btn {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 空状态 */
.empty-state {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.empty-title {
  font-size: 36rpx;
  color: #ffffff;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 60rpx;
}

.btn-go-test {
  background: linear-gradient(135deg, #45a29e 0%, #66fcf1 100%);
  color: #0b0c10;
  font-size: 30rpx;
  font-weight: bold;
  padding: 24rpx 60rpx;
  border-radius: 48rpx;
  letter-spacing: 2rpx;
  border: none;
}

/* 历史列表 */
.history-list {
  position: relative;
  z-index: 10;
  height: calc(100vh - 180rpx);
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

.history-item {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.item-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.item-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
}

.item-content {
  margin-bottom: 20rpx;
}

.item-quote {
  font-size: 28rpx;
  color: #e0e0e0;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.item-tag {
  font-size: 22rpx;
  color: #66fcf1;
  background: rgba(102, 252, 241, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.item-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
}