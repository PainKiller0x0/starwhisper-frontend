page {
  background-color: #0b0c10;
  color: #c5c6c7;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  overflow: hidden;
}

.page-container {
  width: 100%;
  height: 100vh;
  position: relative;
  background: radial-gradient(circle at center, #1f2833 0%, #0b0c10 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 繁星背景动画辅助 */
.stars {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    radial-gradient(2px 2px at 20px 30px, #ffffff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.8), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 50px 160px, rgba(255,255,255,0.6), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 90px 40px, rgba(255,255,255,0.9), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 130px 80px, rgba(255,255,255,0.5), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 160px 120px, rgba(255,255,255,0.7), rgba(0,0,0,0));
  background-repeat: repeat;
  background-size: 200px 200px;
  animation: animateStars 50s linear infinite;
  opacity: 0.5;
  z-index: 0;
  pointer-events: none;
}

@keyframes animateStars {
  0% { transform: translateY(0); }
  100% { transform: translateY(-200px); }
}

/* 玻璃拟态卡片容器 */
.glass-panel {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  width: 100%;
  max-width: 800rpx;
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.8s ease-out;
  box-sizing: border-box;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 64rpx;
  color: #66fcf1;
  opacity: 0.8;
}

.input-group {
  margin-bottom: 48rpx;
  width: 100%;
}

.input-label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  color: #ffffff;
}

.custom-input, .custom-textarea {
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  color: #fff;
  font-size: 32rpx;
  box-sizing: border-box;
  transition: all 0.3s;
}

.custom-input {
  height: 100rpx;
  min-height: 100rpx;
  padding: 0 32rpx;
}

.custom-textarea {
  height: 160rpx;
  padding: 24rpx 32rpx;
}

.placeholder {
  color: #6c757d;
}

.btn-primary {
  background: linear-gradient(135deg, #45a29e 0%, #66fcf1 100%);
  color: #0b0c10;
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  width: 100%;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 252, 241, 0.3);
}

/* 加载动画 */
.loader-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  z-index: 10;
}

.orb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #66fcf1, transparent);
  box-shadow: 0 0 80rpx #66fcf1;
  animation: pulseOrb 2s ease-in-out infinite alternate;
  margin-bottom: 48rpx;
}

@keyframes pulseOrb {
  0% { transform: scale(0.8); opacity: 0.6; }
  100% { transform: scale(1.1); opacity: 1; }
}

.loader-text {
  color: #ffffff;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  animation: breathe 2s infinite alternate;
}

@keyframes breathe {
  0% { opacity: 0.5; }
  100% { opacity: 1; }
}

/* 后端返回海报UI */
.poster-view {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  animation: fadeIn 1s ease-out;
  z-index: 10;
  position: relative;
}

.btn-back {
  position: absolute;
  top: 40rpx;
  left: 0;
  color: #c5c6c7;
  font-size: 28rpx;
  padding: 20rpx;
  z-index: 20;
}

.poster-box {
  width: 660rpx;
  height: 1100rpx;
  background: linear-gradient(180deg, #1f2833 0%, #0b0c10 100%);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5);
  padding: 60rpx 50rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.top-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding-bottom: 30rpx;
}

.poster-title {
  font-size: 40rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  color: #66fcf1;
}

.poster-date {
  font-size: 24rpx;
  opacity: 0.6;
  letter-spacing: 2rpx;
}

.content-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 60rpx 0;
}

.quote-wrapper {
  position: relative;
}

.quote-mark {
  position: absolute;
  top: -60rpx;
  left: -20rpx;
  font-size: 120rpx;
  color: rgba(102, 252, 241, 0.2);
  font-family: serif;
}

.quote {
  font-size: 34rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: #c5c6c7;
  position: relative;
  z-index: 2;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 60rpx;
}

.tag {
  background-color: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #66fcf1;
  letter-spacing: 2rpx;
}

.bottom-section {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 30rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
}

.advice {
  font-size: 26rpx;
  color: #c5c6c7;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.footer-info {
  font-size: 20rpx;
  color: rgba(255,255,255,0.3);
  letter-spacing: 4rpx;
}

.tip-text {
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
  letter-spacing: 2rpx;
  text-align: center;
}
