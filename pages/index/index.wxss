page {
  background-color: #0b0c10;
  color: #c5c6c7;
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  overflow: hidden;
}

.page-container {
  width: 100%;
  height: 100vh;
  position: relative;
  background: radial-gradient(circle at center, #1f2833 0%, #0b0c10 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 繁星背景动画辅助 */
.stars {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    radial-gradient(2px 2px at 20px 30px, #ffffff, rgba(0,0,0,0)),
    radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.8), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 50px 160px, rgba(255,255,255,0.6), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 90px 40px, rgba(255,255,255,0.9), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 130px 80px, rgba(255,255,255,0.5), rgba(0,0,0,0)),
    radial-gradient(2px 2px at 160px 120px, rgba(255,255,255,0.7), rgba(0,0,0,0));
  background-repeat: repeat;
  background-size: 200px 200px;
  animation: animateStars 50s linear infinite;
  opacity: 0.5;
  z-index: 0;
  pointer-events: none;
}

@keyframes animateStars {
  0% { transform: translateY(0); }
  100% { transform: translateY(-200px); }
}

/* 玻璃拟态卡片容器 */
.glass-panel {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  width: 100%;
  max-width: 800rpx;
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.8s ease-out forwards;
  box-sizing: border-box;
  transition: opacity 0.5s ease, transform 0.5s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeOut {
  from { opacity: 1; transform: translateY(0); }
  to { opacity: 0; transform: translateY(-40rpx); }
}

.glass-panel.fade-out {
  animation: fadeOut 0.5s ease-out forwards;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 64rpx;
  color: #66fcf1;
  opacity: 0.8;
}

.input-group {
  margin-bottom: 48rpx;
  width: 100%;
}

.input-label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  color: #ffffff;
}

.custom-input, .custom-textarea {
  width: 100%;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  color: #fff;
  font-size: 32rpx;
  box-sizing: border-box;
  transition: all 0.3s;
}

.custom-input {
  height: 100rpx;
  min-height: 100rpx;
  padding: 0 32rpx;
}

.custom-textarea {
  height: 160rpx;
  padding: 24rpx 32rpx;
}

.placeholder {
  color: #6c757d;
}

.btn-primary {
  background: linear-gradient(135deg, #45a29e 0%, #66fcf1 100%);
  color: #0b0c10;
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  width: 100%;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 252, 241, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(102, 252, 241, 0.2);
}

.btn-primary.btn-loading {
  background: linear-gradient(135deg, #3a8a87 0%, #45a29e 100%);
  opacity: 0.8;
  animation: pulseBtn 1.5s infinite;
}

@keyframes pulseBtn {
  0% { opacity: 0.8; }
  50% { opacity: 1; }
  100% { opacity: 0.8; }
}

.btn-primary.btn-loading::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

/* 加载动画 */
.loader-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  z-index: 10;
  animation: fadeInLoader 0.8s ease-out forwards;
}

@keyframes fadeInLoader {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.orb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #66fcf1, transparent);
  box-shadow: 0 0 100rpx #66fcf1, 0 0 200rpx rgba(102, 252, 241, 0.3);
  animation: pulseOrb 2s ease-in-out infinite, rotateOrb 8s linear infinite;
  margin-bottom: 60rpx;
}

@keyframes pulseOrb {
  0% { transform: scale(0.8); opacity: 0.7; box-shadow: 0 0 80rpx #66fcf1; }
  50% { transform: scale(1.0); opacity: 1; box-shadow: 0 0 120rpx #66fcf1, 0 0 200rpx rgba(102, 252, 241, 0.4); }
  100% { transform: scale(0.8); opacity: 0.7; box-shadow: 0 0 80rpx #66fcf1; }
}

@keyframes rotateOrb {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loader-text {
  color: #ffffff;
  font-size: 32rpx;
  letter-spacing: 6rpx;
  animation: breathe 2s infinite alternate, textGlow 2s infinite alternate;
  text-shadow: 0 0 20rpx rgba(102, 252, 241, 0.5);
}

@keyframes breathe {
  0% { opacity: 0.6; transform: translateY(0); }
  100% { opacity: 1; transform: translateY(-10rpx); }
}

@keyframes textGlow {
  from { text-shadow: 0 0 20rpx rgba(102, 252, 241, 0.5); }
  to { text-shadow: 0 0 40rpx rgba(102, 252, 241, 0.8), 0 0 60rpx rgba(102, 252, 241, 0.3); }
}

/* 加载完成动画 */
.loader-container.complete {
  animation: fadeOutLoader 0.6s ease-out forwards;
}

@keyframes fadeOutLoader {
  from { opacity: 1; transform: scale(1); }
  to { opacity: 0; transform: scale(1.1); }
}

/* 小球呼吸动画 */
.orb.breathing {
  animation: pulseOrb 2s ease-in-out infinite, rotateOrb 8s linear infinite;
}

/* 小球飞行动画 */
.orb.flying {
  animation: flyOrb 1.2s ease-in-out forwards;
}

@keyframes flyOrb {
  0% {
    transform: scale(0.8) translateY(0);
    opacity: 0.7;
  }
  30% {
    transform: scale(1.2) translateY(0);
    opacity: 1;
  }
  100% {
    transform: scale(0.3) translateY(-100vh);
    opacity: 0;
  }
}

/* 飞行阶段的容器 */
.loader-container.flying {
  animation: fadeOutContainer 1.2s ease-in-out forwards;
}

@keyframes fadeOutContainer {
  0% {
    opacity: 1;
  }
  100% {
    opacity: 0;
  }
}

/* 飞行阶段的文字 */
.loader-text.flying {
  animation: fadeOutText 0.8s ease-out forwards;
}

@keyframes fadeOutText {
  0% {
    opacity: 1;
    transform: translateY(0);
  }
  100% {
    opacity: 0;
    transform: translateY(20rpx);
  }
}

/* 结果容器 */
.result-container {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: linear-gradient(180deg, rgba(11, 12, 16, 0.95) 0%, rgba(11, 12, 16, 1) 100%);
  transform: translateY(100%);
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 100;
  overflow-y: auto;
}

.result-container.slide-up {
  transform: translateY(0);
}

/* 结果内容 */
.result-content {
  padding: 60rpx 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 结果头部 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 30rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  margin-bottom: 40rpx;
}

.result-title {
  font-size: 48rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  color: #66fcf1;
  animation: fadeInTitle 0.6s ease-out 0.3s both;
}

@keyframes fadeInTitle {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.result-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 2rpx;
  animation: fadeInDate 0.6s ease-out 0.4s both;
}

@keyframes fadeInDate {
  from {
    opacity: 0;
  }
  to {
    opacity: 0.5;
  }
}

/* 结果主体 */
.result-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40rpx 0;
}

.quote-wrapper {
  position: relative;
  margin-bottom: 60rpx;
  animation: fadeInQuote 0.8s ease-out 0.5s both;
}

@keyframes fadeInQuote {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.quote-mark {
  position: absolute;
  top: -40rpx;
  left: -20rpx;
  font-size: 120rpx;
  color: rgba(102, 252, 241, 0.15);
  font-family: serif;
  animation: fadeInQuoteMark 0.6s ease-out 0.6s both;
}

@keyframes fadeInQuoteMark {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 0.15;
    transform: scale(1);
  }
}

.quote {
  font-size: 36rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: #c5c6c7;
  position: relative;
  z-index: 2;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  animation: fadeInTags 0.6s ease-out 0.7s both;
}

@keyframes fadeInTags {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tag {
  background-color: rgba(102, 252, 241, 0.1);
  border: 1px solid rgba(102, 252, 241, 0.3);
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #66fcf1;
  letter-spacing: 2rpx;
}

/* 结果底部 */
.result-footer {
  padding-top: 40rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  text-align: center;
  animation: fadeInFooter 0.6s ease-out 0.9s both;
}

@keyframes fadeInFooter {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.advice {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.footer-info {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 4rpx;
}

/* 返回按钮 */
.btn-back {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #c5c6c7;
  border-radius: 48rpx;
  padding: 24rpx 60rpx;
  font-size: 30rpx;
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  animation: fadeInButton 0.6s ease-out 1s both;
}

@keyframes fadeInButton {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

