<view class="page-container">
  <!-- 繁星背景 -->
  <view class="stars"></view>

  <!-- 输入域 -->
  <view class="glass-panel {{step === 'loading' ? 'fade-out' : ''}}" wx:if="{{step === 'input' || step === 'loading'}}">
    <view class="title">星 言</view>
    <view class="subtitle">专属你的疗愈星空</view>
    
    <view class="input-group">
      <text class="input-label">你的名字 / 昵称</text>
      <input 
        class="custom-input" 
        placeholder="例如: 小星" 
        placeholder-class="placeholder"
        model:value="{{name}}"
        disabled="{{step === 'loading'}}"
      />
    </view>
    
    <view class="input-group">
      <text class="input-label">当下的困扰 / 情绪</text>
      <textarea 
        class="custom-textarea" 
        placeholder="例如: 最近工作压力好大，很迷茫..." 
        placeholder-class="placeholder"
        model:value="{{trouble}}"
        disabled="{{step === 'loading'}}"
      ></textarea>
    </view>
    
    <button 
      class="btn-primary {{step === 'loading' ? 'btn-loading' : ''}}" 
      bindtap="generateReading"
      disabled="{{step === 'loading'}}"
    >
      {{step === 'loading' ? '连接中...' : '开启星空指引'}}
    </button>
  </view>

  <!-- 加载状态 - 呼吸阶段 -->
  <view class="loader-container" wx:if="{{step === 'breathing'}}">
    <view class="orb breathing"></view>
    <view class="loader-text">正在连接你的专属磁场...</view>
  </view>

  <!-- 加载状态 - 飞行阶段 -->
  <view class="loader-container flying" wx:if="{{step === 'flying'}}">
    <view class="orb flying"></view>
    <view class="loader-text flying">星空指引已送达...</view>
  </view>

  <!-- 结果展示 -->
  <view class="result-page" wx:if="{{step === 'result'}}">
    <view class="result-scroll">
      <!-- 海报卡片 -->
      <view class="poster-card">
        <!-- 顶部 -->
        <view class="poster-top">
          <text class="poster-logo">星 言</text>
          <text class="poster-date">{{todayDate}}</text>
        </view>

        <!-- 核心内容 -->
        <view class="poster-main">
          <view class="poster-quote-box">
            <text class="poster-quote-mark">"</text>
            <text class="poster-quote-text">{{reading.quote}}</text>
          </view>

          <view class="poster-tags">
            <block wx:for="{{reading.tags}}" wx:key="*this">
              <text class="poster-tag">#{{item}}</text>
            </block>
          </view>
        </view>

        <!-- 底部 -->
        <view class="poster-bottom">
          <text class="poster-advice">{{reading.advice}}</text>
          <text class="poster-footer">长按保存 · 开启深度解析</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="result-actions">
        <button class="btn-retry" bindtap="resetFlow">重新测试</button>
      </view>
    </view>
  </view>
</view>