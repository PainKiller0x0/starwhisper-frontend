<view class="page-container">
  <!-- 繁星背景 -->
  <view class="stars"></view>

  <!-- 输入域 -->
  <view class="glass-panel" wx:if="{{step === 'input'}}">
    <view class="title">星 言</view>
    <view class="subtitle">专属你的疗愈星空</view>
    
    <view class="input-group">
      <text class="input-label">你的名字 / 昵称</text>
      <input 
        class="custom-input" 
        placeholder="例如: 小星" 
        placeholder-class="placeholder"
        model:value="{{name}}" 
      />
    </view>
    
    <view class="input-group">
      <text class="input-label">当下的困扰 / 情绪</text>
      <textarea 
        class="custom-textarea" 
        placeholder="例如: 最近工作压力好大，很迷茫..." 
        placeholder-class="placeholder"
        model:value="{{trouble}}"
      ></textarea>
    </view>
    
    <button class="btn-primary" bindtap="generateReading">开启星空指引</button>
  </view>

  <!-- 加载状态 -->
  <view class="loader-container" wx:if="{{step === 'loading'}}">
    <view class="orb"></view>
    <view class="loader-text">正在连接你的专属磁场...</view>
  </view>
</view>