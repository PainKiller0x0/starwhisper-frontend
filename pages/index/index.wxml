<view class="page-container">
  <!-- 繁星背景 -->
  <view class="stars"></view>

  <!-- 输入域 -->
  <view class="glass-panel" wx:if="{{step === 'input'}}">
    <view class="title">星 言</view>
    <view class="subtitle">专属你的疗愈星空</view>
    
    <view class="input-group">
      <text class="input-label">你的名字 / 昵称</text>
      <input 
        class="custom-input" 
        placeholder="例如: 小星" 
        placeholder-class="placeholder"
        model:value="{{name}}" 
      />
    </view>
    
    <view class="input-group">
      <text class="input-label">当下的困扰 / 情绪</text>
      <textarea 
        class="custom-textarea" 
        placeholder="例如: 最近工作压力好大，很迷茫..." 
        placeholder-class="placeholder"
        model:value="{{trouble}}" 
      ></textarea>
    </view>
    
    <button class="btn-primary" bindtap="generateReading">开启星空指引</button>
  </view>

  <!-- 加载状态 -->
  <view class="loader-container" wx:if="{{step === 'loading'}}">
    <view class="orb"></view>
    <view class="loader-text">正在连接你的专属磁场...</view>
  </view>
</view>
</view>

  <!-- 结果海报展示 -->
  <view class="poster-view" wx:if="{{step === 'poster' && reading}}">
    <view class="btn-back" bindtap="resetFlow">← 重新测试</view>
    
    <view class="poster-box" id="poster">
      <view class="top-section">
        <text class="poster-title">星 言</text>
        <text class="poster-date">{{todayDate}}</text>
      </view>

      <view class="content-section">
        <view class="quote-wrapper">
          <text class="quote-mark">“</text>
          <text class="quote">{{reading.quote}}</text>
        </view>
        
        <view class="tags-container">
          <block wx:for="{{reading.tags}}" wx:key="*this">
            <text class="tag"># {{item}}</text>
          </block>
        </view>
      </view>

      <view class="bottom-section">
        <text class="advice">{{reading.advice}}</text>
        <text class="footer-info">长按保存图片 · 开启深度解析</text>
      </view>
    </view>
    
    <!-- 长按提示由于目前只是UI海报，可以利用小程序官方的保存组件或直接截图展示，这里先保持UI一致性 -->
    <view class="tip-text">✨ 截图保存属于你的星空疗愈 ✨</view>
  </view>
</view>
